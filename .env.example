# ============================================================
# Sol Monitor — Environment Configuration
# 复制此文件为 .env 并填写实际值
# ============================================================

# ── BirdEye API（必填）──────────────────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Helius API（可选，暂未使用，预留）──────────────────────
HELIUS_API_KEY=your_helius_api_key_here

# ── 本服务监听端口 ───────────────────────────────────────────
PORT=3003

# ── 交易机器人 Webhook 地址 ──────────────────────────────────
# BUY  → http://TRADE_BOT_HOST:TRADE_BOT_PORT/webhook/new-token
# SELL → http://TRADE_BOT_HOST:TRADE_BOT_PORT/force-sell
TRADE_BOT_HOST=localhost
TRADE_BOT_PORT=3002

# ── 代币监控参数 ─────────────────────────────────────────────
# 代币在白名单内的最大存活时间（分钟），超时自动发 SELL 并移除
TOKEN_MAX_AGE_MINUTES=30

# K 线聚合周期（秒），默认 5s
CANDLE_INTERVAL_SECONDS=5

# ── RSI 参数 ─────────────────────────────────────────────────
RSI_PERIOD=7
RSI_BUY_CROSS=30          # RSI 上穿阈值

# ── 买入条件 ─────────────────────────────────────────────────
# 价格较收录时参考价的最小跌幅（%），与 RSI 上穿同时满足才买入
BUY_DROP_PCT=20

# ── 卖出条件 ─────────────────────────────────────────────────
SELL_TP_PCT=150            # 止盈：持仓盈利达到此百分比时卖出
SELL_SL_PCT=30             # 止损：持仓亏损达到此百分比时卖出
